SYSTEM        windows
NAME          ..\build\WOLFA20.EXE
FILE          ..\build\wolfvis_a20.obj
OPTION        MAP=..\build\WOLFA20.MAP
OPTION        QUIET
OPTION        DESCRIPTION 'WolfVIS A.20 enemy fire-back + player health (gameplay loop closure)'
